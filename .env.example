# ==============================================================================
# HotPlex Environment Configuration Template (English)
# ==============================================================================
# Usage: Copy this file to .env and configure for your environment.

# ------------------------------------------------------------------------------
# 1. CORE SERVER SETTINGS
# ------------------------------------------------------------------------------

# Port the HotPlex proxy server will listen on (default: 8080)
PORT=8080

# Backend Provider Type:
# - claude: Use Anthropic Claude Code CLI (default)
# - opencode: Use OpenCode CLI
HOTPLEX_PROVIDER_TYPE=claude

# CLI Binary Path:
# If empty, HotPlex will automatically search in system $PATH (e.g., 'claude' or 'opencode')
HOTPLEX_PROVIDER_BINARY=

# Model Name Alias (optional):
# e.g., 'sonnet' or specific version string. If empty, the underlying CLI decides.
HOTPLEX_PROVIDER_MODEL=sonnet

# OpenCode HTTP API Compatibility Layer (default: true)
# When enabled, supports /session and /global routes for easy legacy integration.
HOTPLEX_OPENCODE_COMPAT_ENABLED=true


# ------------------------------------------------------------------------------
# 2. RUNTIME PERFORMANCE & TIMEOUTS
# ------------------------------------------------------------------------------

# Execution Timeout per turn (default: 30m)
# AI processes will be terminated if they run longer than this to prevent resource leaks.
EXECUTION_TIMEOUT=30m

# Session Idle Timeout (default: 30m)
# HotPlex will terminate backend CLI processes after this duration of inactivity.
IDLE_TIMEOUT=30m

# Log Level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO


# ------------------------------------------------------------------------------
# 3. SECURITY & AUTHENTICATION
# ------------------------------------------------------------------------------

# CORS Allowed Origins: Comma-separated list.
# Required only for browser-based clients (e.g., a React frontend).
HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# API Access Key (Required for production):
# Clients must provide this key via X-API-Key header or ?api_key= query parameter.
HOTPLEX_API_KEY=generate-a-strong-random-key-here


# ------------------------------------------------------------------------------
# 4. CHATAPPS PLATFORM (Bot Adapters)
# ------------------------------------------------------------------------------

# Enable/Disable the ChatBot adapter layer globally (default: false)
CHATAPPS_ENABLED=false

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# --- Discord Bot ---
DISCORD_BOT_TOKEN=

# --- Slack App ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ------------------------------------------------------------------------------
# 5. MONITORING & NOTIFICATIONS
# ------------------------------------------------------------------------------

# DingTalk Alert Configuration (for system errors and security blocks)
HOTPLEX_DINGTALK_ENABLED=false
HOTPLEX_DINGTALK_WEBHOOK_URL=
HOTPLEX_DINGTALK_SECRET=
# Types of events that trigger a notification
HOTPLEX_DINGTALK_FILTER_EVENTS=danger.blocked,session.error
