# ==============================================================================
# HotPlex 环境变量配置模版 (中文)
# ==============================================================================
# 使用说明: 复制此文件并重命名为 .env，然后根据你的开发/生产环境进行修改。

# ------------------------------------------------------------------------------
# 1. 核心服务设置 (Core Server)
# ------------------------------------------------------------------------------

# 服务监听端口 (默认: 8080)
PORT=8080

# 后端 Provider 类型: 
# - claude: 使用 Anthropic Claude Code CLI (默认)
# - opencode: 使用 OpenCode CLI
HOTPLEX_PROVIDER_TYPE=claude

# CLI 二进制文件路径:
# 如果为空，HotPlex 将自动在系统 $PATH 中搜索 (如 'claude' 或 'opencode')
HOTPLEX_PROVIDER_BINARY=

# 模型名称别名 (选填):
# 例如 'sonnet' 或具体的版本号。如果不填，由底层 CLI 决定其默认模型。
HOTPLEX_PROVIDER_MODEL=sonnet

# OpenCode HTTP 协议兼容层开关 (默认: true)
# 开启后，支持 /session, /config 等 OpenCode 风格接口，方便现有插件直接接入。
HOTPLEX_OPENCODE_COMPAT_ENABLED=true


# ------------------------------------------------------------------------------
# 2. 运行性能与超时 (Performance & Timeout)
# ------------------------------------------------------------------------------

# 单次交互执行超时 (默认: 30m)
# 超过此时间 AI 进程将被强制中断，防止任务陷入死循环导致资源耗尽。
EXECUTION_TIMEOUT=30m

# 会话闲置回收时间 (默认: 30m)
# 会话在此时间内没有新输入时，HotPlex 会主动杀掉关联的后台 CLI 进程以释放内存。
IDLE_TIMEOUT=30m

# 日志级别: DEBUG (开发推荐), INFO (标准), WARN, ERROR
LOG_LEVEL=INFO


# ------------------------------------------------------------------------------
# 3. 安全与权限 (Security & Auth)
# ------------------------------------------------------------------------------

# 跨域白名单 (CORS): 多个地址用逗号分隔。
# 仅当浏览器客户端接入（如可视化面板）时需要。
HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# API 访问密钥 (生产环境必备):
# 客户端必须在 Header (X-API-Key) 中提供此 Key 才能连接。
HOTPLEX_API_KEY=your-generate-strong-random-key-here


# ------------------------------------------------------------------------------
# 4. 聊天应用适配器 (ChatApps Bot)
# ------------------------------------------------------------------------------

# 是否全局开启 ChatBot 适配层 (默认: false)
CHATAPPS_ENABLED=false

# --- Telegram Bot (从 @BotFather 获取) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# --- Discord Bot (从 Discord Developer Portal 获取) ---
DISCORD_BOT_TOKEN=

# --- Slack App (支持 Socket Mode 或 Webhook) ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ------------------------------------------------------------------------------
# 5. 系统告警与通知 (Notifications)
# ------------------------------------------------------------------------------

# 钉钉机器人告警配置 (用于接收系统异常、敏感操作拦截等通知)
HOTPLEX_DINGTALK_ENABLED=false
HOTPLEX_DINGTALK_WEBHOOK_URL=
HOTPLEX_DINGTALK_SECRET=
# 过滤触发通知的事件类型
HOTPLEX_DINGTALK_FILTER_EVENTS=danger.blocked,session.error
